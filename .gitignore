name: Node.js CI

on:
  push:
    branches: [ main ] # أو master حسب اسم فرعك الأساسي

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v3
    - name: Use Node.js
      uses: actions/setup-node@v3
      with:
        node-version: '18.x'
    - run: npm install
    - run: npm run build # سيقوم ببناء المشروع والتأكد من عدم وجود ملفات تالفة
